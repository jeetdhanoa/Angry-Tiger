# ── Supabase (required) ─────────────────────────────────────────────
# Project Settings → API. Both are safe to expose in the browser:
# the anon key is the public "publishable" key.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# ── Supabase service role (recommended for launch) ──────────────────
# SECRET — server-only, never NEXT_PUBLIC, never commit. Supabase →
# Project Settings → API keys. When set, /api/forms writes with this
# key; you can then revoke the anon INSERT grants (see supabase/setup.sql)
# so the rate-limited, CAPTCHA-checked route is the only way in.
# SUPABASE_SERVICE_ROLE_KEY=

# ── Cloudflare Turnstile CAPTCHA (optional) ─────────────────────────
# Free at https://dash.cloudflare.com → Turnstile. Widgets appear on the
# newsletter / waitlist / contact / sign-in forms as soon as the site key
# exists; the secret activates server-side verification in /api/forms.
# Paste the same secret in Supabase → Auth → Attack protection to protect
# sign-in/sign-up too.
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=

# Local dev: copy this file to .env.local and fill in real values.
# Production: add the same vars in Vercel → Project → Settings →
# Environment Variables, then redeploy.
